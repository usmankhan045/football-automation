# Copy this file to `.env` (same folder) and fill in your secrets.
#   cp .env.example .env
# The backend auto-loads it via load_dotenv() on startup. Never commit `.env`.

# --- Llama 4 via Groq (REQUIRED for live script generation) ---
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional: override the default Llama 4 model id used in graph.py
# MODEL_NAME=meta-llama/llama-4-scout-17b-16e-instruct

# --- Highlightly (PRIMARY data source — deep xG/possession, no IP blocking) ---
# Node A sends it as the x-api-key header to
# GET https://sports.highlightly.net/football/matches/{matchId}.
# Start a workflow with the Highlightly match id as the match_id.
HIGHLIGHTLY_API_KEY=
# Optional backups. The backend automatically tries these when the primary key
# returns quota/rate-limit/auth errors and sends a warning to the dashboard.
# HIGHLIGHTLY_API_KEY_2=
# HIGHLIGHTLY_API_KEYS=primary_key,backup_key_2,backup_key_3
# HIGHLIGHTLY_HOST=https://sports.highlightly.net/football   # override if needed

# --- football-data.org token (FALLBACK — latest finished World Cup match) ---
# Free token: https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=
# Optional: pin a season (defaults to 2026)
# FOOTBALL_DATA_SEASON=2026

# --- CORS (optional) ---
# Comma-separated browser origins allowed to call the API.
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Video render mode (optional) ---
# off (default) | stub (offline MoviePy 9:16) | real (Edge TTS + Whisper)
# VIDEO_RENDER_MODE=off
